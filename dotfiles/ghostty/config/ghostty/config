font-family = JetBrainsMono Nerd Font Mono
font-size = 14
theme = GruvboxDarkHard
window-padding-x = 6
window-padding-y = 6
window-save-state = always
macos-option-as-alt = true
copy-on-select = clipboard
mouse-hide-while-typing = true

# Splits are the primary knob for running multiple claude agents in panes.
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+left_bracket=goto_split:previous
keybind = cmd+right_bracket=goto_split:next
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+w=close_surface

# Global hotkey: drop-down terminal for a quick claude session.
quick-terminal-position = top
quick-terminal-animation-duration = 0.1
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Machine-local overrides. `?` prefix makes the load optional.
config-file = ?~/.config/ghostty/config.local
