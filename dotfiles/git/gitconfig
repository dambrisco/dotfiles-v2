[init]
	defaultBranch = main
[pull]
	rebase = true
[rebase]
	autoStash = true
[core]
	pager = delta
	editor = nvim
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	light = false
	syntax-theme = gruvbox-dark
[color]
	ui = auto
[push]
	default = current
	autoSetupRemote = true
[merge]
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
	colorMoved = default
[user]
	name = DJ Ambrisco
	email = dambrisco@gmail.com
# Per-directory identity overrides. The included file is regenerated by
# lib/gen-gitconfig-includes.sh from ~/.gitconfig.<dir> files matching
# subdirectories of ~/src/.
[include]
	path = ~/.gitconfig.d/includes
# Machine-local overrides (signing keys, credential helpers, etc.).
[include]
	path = ~/.gitconfig.local
